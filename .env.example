PORT=3000
JWT_SECRET=replace_with_random_32_char_string_here
NODE_ENV=production

# ── Email digest nhắc việc 07:30 sáng (giờ VN) ──────────────
# Cách 1 (khuyên dùng trên Railway gói Trial — SMTP bị chặn): Resend API qua HTTPS
# Tạo tài khoản miễn phí tại https://resend.com → API Keys → tạo key
# (chưa verify domain thì chỉ gửi được tới email chủ tài khoản, from = onboarding@resend.dev)
RESEND_API_KEY=

# Cách 2: SMTP truyền thống (Gmail App Password — cần hạ tầng cho phép cổng 587)
# Gmail: bật 2FA rồi tạo App Password tại https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM="Booking Hub <your_email@gmail.com>"
# Link mở app trong email (đổi thành domain Railway khi deploy)
APP_URL=http://localhost:3000

# ── Zalo OA — kênh nhắc việc thứ 2 (bỏ trống = tắt) ────────
# 1. Tạo Zalo OA cho công ty tại oa.zalo.me (cần xác thực doanh nghiệp)
# 2. Tạo app tại developers.zalo.me, liên kết với OA, bật quyền gửi tin nhắn
# 3. Lấy refresh token lần đầu qua công cụ OAuth trên developers.zalo.me
#    (sau đó app tự refresh và lưu token mới vào data/zalo_token.json)
# 4. Nhân viên follow OA → CEO vào Quản lý User bấm "Tra Zalo ID" để gán
ZALO_APP_ID=
ZALO_APP_SECRET=
ZALO_REFRESH_TOKEN=

# ── Webhook cho website CTY2 (bỏ trống = tắt endpoint) ─────
# Website gửi POST /api/webhook/bookings với header X-API-Key
WEBHOOK_API_KEY=
